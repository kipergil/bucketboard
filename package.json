{
  "name": "bucketboard",
  "private": true,
  "version": "0.1.0",
  "description": "BucketBoard — multi-tenant community favourites platform on Directus + Next.js",
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "build": "pnpm -r --filter=./packages/* --filter=./apps/web build",
    "dev": "pnpm --filter=./apps/web dev",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "db:seed": "pnpm --filter=./apps/directus seed",
    "schema:apply": "pnpm --filter=./apps/directus schema:apply",
    "schema:snapshot": "pnpm --filter=./apps/directus schema:snapshot",
    "tenant:clone": "pnpm --filter=./apps/directus tenant:clone",
    "prepare": "husky"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "eslint": "^9.17.0",
    "husky": "^9.1.7",
    "prettier": "^3.4.2",
    "prettier-plugin-tailwindcss": "^0.6.11",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.19.0"
  }
}
