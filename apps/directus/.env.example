# --- Directus core ---
KEY=replace-with-a-random-uuid
SECRET=replace-with-a-long-random-secret

DB_CLIENT=pg
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=directus
DB_USER=directus
DB_PASSWORD=directus

CACHE_ENABLED=true
CACHE_STORE=redis
REDIS=redis://redis:6379

ADMIN_EMAIL=admin@bucketboard.dev
ADMIN_PASSWORD=replace-with-a-strong-password

PUBLIC_URL=http://localhost:8055
CORS_ENABLED=true
CORS_ORIGIN=http://localhost:3000

STORAGE_LOCATIONS=local
STORAGE_LOCAL_ROOT=./uploads

# Direct Postgres connection (host-mapped port), used only by
# schema/constraints.ts to add composite unique indexes Directus's schema
# API can't express, and by seed/tenant-clone scripts run from the host.
DATABASE_URL=postgresql://directus:directus@localhost:5432/directus

# Long-lived static token used by the Next.js BFF (server actions) to talk
# to Directus as the narrowly-scoped "Service" role (see
# src/permissions/definitions.ts) — never admin, never exposed to the
# browser. Generated by `pnpm --filter=./apps/directus permissions:apply`
# on first run and printed to the console — paste it here and into
# apps/web/.env.local as DIRECTUS_SERVICE_TOKEN.
# SERVICE_TOKEN=

# --- Optional: enrichment / LLM provider for the offer enrichment queue ---
# The `enrichment_jobs` collection and its permissions exist, but no worker
# processes the queue yet — these are reserved for that future worker.
# ENRICHMENT_LLM_API_KEY=
# ENRICHMENT_LLM_MODEL=claude-sonnet-5

# --- Clerk webhook (verified by the Next.js route handler, listed here for reference) ---
# CLERK_WEBHOOK_SECRET=
